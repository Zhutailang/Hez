# Hez — copy to .env and adjust
PORT=3001
JWT_SECRET=change-me-to-a-random-secret
DATABASE_PATH=./data/hez.db
# Defaults for settings table (overridable in /admin after boot)
LIVEKIT_URL=ws://localhost:7880
# Optional: Room Service HTTP base
# LIVEKIT_API_URL=http://127.0.0.1:7880
# HEZ_LK_SEOUL_API=http://127.0.0.1:17880
# HEZ_LK_API_INSECURE=1
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret
CORS_ORIGIN=http://localhost:5173
# Bootstrap admin (created once if missing)
HEZ_ADMIN_USERNAME=Admin
HEZ_ADMIN_PASSWORD=your-admin-password
# HEZ_ADMIN_RESET=1

# Auto start/stop LiveKit when admin saves selected node (Seoul API controls both)
HEZ_LK_LOCAL_DIR=/opt/hez
HEZ_LK_CN_HOST=your-cn-server-ip
HEZ_LK_CN_USER=root
HEZ_LK_CN_PASSWORD=
HEZ_LK_CN_DIR=/opt/hez
